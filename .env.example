# ─── 0G Aristotle Mainnet (Chain ID 16661) — switch to Galileo testnet (16602) for staging ───
ZEROG_RPC_URL=https://evmrpc.0g.ai
ZEROG_CHAIN_ID=16661
ZEROG_EXPLORER=https://chainscan.0g.ai

# Deployer wallet (must hold ≥1 OG on the target chain)
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=

# ─── 0G Compute (Sealed Inference, TeeML providers) ────────────────────────
# npm: @0gfoundation/0g-compute-ts-sdk@^0.8.0
# Per-inference attestation = EIP-191 ECDSA secp256k1, verifiable in Solidity ~3-5k gas.
# Full DCAP TEE quote verify on-chain = 5-15M gas (out of v1 scope; ECDSA path used instead).
ZEROG_BROKER_RPC=https://evmrpc.0g.ai
SEALED_INFERENCE_MODEL=deepseek-v3
FALLBACK_INFERENCE_MODEL=glm-5-744b

# ─── 0G Storage ────────────────────────────────────────────────────────────
ZEROG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# ─── The Lattice — deployed contract addresses ────────────────────────────
# Populated by `forge script script/DeployLattice.s.sol` output.
SOUL_INFT_ADDR=
LATTICE_ATTESTOR_ADDR=
LATTICE_REGISTRY_ADDR=
# Provider EVM address registered in LatticeAttestor (for the dev/demo path,
# set this to the same address as the TEE signer below; production = the
# actual 0G Compute provider's EVM address).
LATTICE_TEE_PROVIDER=
# Recipient of integer-division dust on N-way royalty fan-out (defaults to deployer).
LATTICE_PROTOCOL_FEE_RECIPIENT=

# TEE attestation signing key. MUST match the address registered as the TEE
# signer in LatticeAttestor (per-provider). For dev/demo we reuse the deployer key.
TEE_STUB_PRIVATE_KEY=

# ─── UI ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://evmrpc.0g.ai
NEXT_PUBLIC_CHAIN_ID=16661
NEXT_PUBLIC_EXPLORER=https://chainscan.0g.ai
# Optional: WalletConnect projectId. Localhost works without it.
NEXT_PUBLIC_WC_PROJECT_ID=
# Lattice orchestrator URL (the Fastify server from this repo).
NEXT_PUBLIC_LATTICE_URL=http://localhost:3001

# ─── Orchestrator runtime ─────────────────────────────────────────────────
ORCHESTRATOR_PORT=3001
ORCHESTRATOR_LOG_LEVEL=info
